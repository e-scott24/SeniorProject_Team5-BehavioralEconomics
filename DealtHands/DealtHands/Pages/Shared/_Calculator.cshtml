@*
    Handles mobile viewing
    Tooltip tap-to-toggle - clicking a .calc-tip badge toggles .open on that badge (and closes any others)
    Snapshot drawer - clicking the toggle flips aria-expanded
*@
<script>
    document.addEventListener("click", function (e) {
        var tip = e.target.closest(".calc-tip");
        document.querySelectorAll(".calc-tip.open").forEach(function (t) {
            if (t !== tip) t.classList.remove("open");
        });
        if (tip) tip.classList.toggle("open");
    });

    var snapshotToggle = document.getElementById("c-snapshot-toggle");
    if (snapshotToggle) {
        snapshotToggle.addEventListener("click", function () {
            var expanded = this.getAttribute("aria-expanded") === "true";
            this.setAttribute("aria-expanded", String(!expanded));
        });
    }
</script>