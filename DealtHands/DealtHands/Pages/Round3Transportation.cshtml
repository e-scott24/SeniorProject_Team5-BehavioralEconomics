@page
@model DealtHands.Pages.Round3TransportationModel
@{
    ViewData["Title"] = "Round 3 - Transportation";
}

<div class="container mt-4">
    <!-- Financial Status Header -->
    <div class="alert alert-info">
        <div class="row text-center">
            <div class="col-md-3">
                <strong>Salary:</strong> $@((Model.Player?.Salary ?? 0).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Monthly:</strong> $@((Model.Player?.MonthlyIncome ?? 0).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Available:</strong> $@(((Model.Player?.MonthlyIncome ?? 0) - (Model.Player?.MonthlyExpenses ?? 0)).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Financial Health:</strong> @(Model.Player?.FinancialHealth ?? "Healthy")
            </div>
            <div class="col-md-3">
                <strong>Round:</strong> 3 of 5
            </div>
        </div>
    </div>

    <div class="text-center mb-4">
        <h2>ROUND 3: TRANSPORTATION</h2>
        <p class="text-muted">How will you get around?</p>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">2020 Toyota Camry</h5>
                    <p class="card-text">Price: $18,500</p>
                    <p class="text-muted">5-Year Loan</p>
                    <p><strong>$320/month</strong></p>
                    <small class="text-muted">+ $150/mo insurance</small>
                    <form method="post" asp-page-handler="SelectVehicle">
                        <input type="hidden" name="playerId" value="@Model.Player?.Id" />
                        <input type="hidden" name="vehicleDescription" value="2020 Toyota Camry" />
                        <input type="hidden" name="monthlyPayment" value="320" />
                        <input type="hidden" name="purchasePrice" value="18500" />
                        <button type="submit" class="btn btn-primary w-100 mt-2">Select</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">2018 Honda Civic</h5>
                    <p class="card-text">Price: $16,500</p>
                    <p class="text-muted">5-Year Loan</p>
                    <p><strong>$285/month</strong></p>
                    <small class="text-muted">+ $130/mo insurance</small>
                    <form method="post" asp-page-handler="SelectVehicle">
                        <input type="hidden" name="playerId" value="@Model.Player?.Id" />
                        <input type="hidden" name="vehicleDescription" value="Used 2018 Honda Civic" />
                        <input type="hidden" name="monthlyPayment" value="250" />
                        <input type="hidden" name="purchasePrice" value="12000" />
                        <button type="submit" class="btn btn-primary w-100 mt-2">Select</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Public Transit</h5>
                    <p class="card-text">No purchase needed</p>
                    <p class="text-muted">Monthly Pass</p>
                    <p><strong>$80/month</strong></p>
                    <small class="text-muted">No insurance needed</small>
                    <form method="post" asp-page-handler="SelectVehicle">
                        <input type="hidden" name="playerId" value="@Model.Player?.Id" />
                        <input type="hidden" name="vehicleDescription" value="Public Transit" />
                        <input type="hidden" name="monthlyPayment" value="80" />
                        <input type="hidden" name="purchasePrice" value="0" />
                        <button type="submit" class="btn btn-primary w-100 mt-2">Select</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>