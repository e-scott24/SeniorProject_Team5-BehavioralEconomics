@page
@model DealtHands.Pages.LobbyModel
@{
    ViewData["Title"] = "Lobby";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Session Code: 12345</h3>
        </div>
        <div class="card-body">
            <h4>Waiting for game to start...</h4>
            <p class="text-muted">Players joined: 12 / 35</p>

            <div class="row">
                <div class="col-md-2 mb-3">
                    <div class="card">
                        <div class="card-body text-center">
                            <p class="mb-0">Alex</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-2 mb-3">
                    <div class="card">
                        <div class="card-body text-center">
                            <p class="mb-0">Sarah</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-2 mb-3">
                    <div class="card">
                        <div class="card-body text-center">
                            <p class="mb-0">Mike</p>
                        </div>
                    </div>
                </div>
                <!-- Add more as needed -->
            </div>

            <div class="alert alert-info mt-4">
                Game will start when teacher is ready!
            </div>
        </div>
    </div>
</div>