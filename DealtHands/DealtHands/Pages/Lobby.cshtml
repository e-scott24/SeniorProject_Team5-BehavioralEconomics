@page
@using DealtHands.Models
@model DealtHands.Pages.LobbyModel
@{
	ViewData["Title"] = "Lobby";
}

<div class="container mt-4">
	<div class="card shadow">
		<div class="card-header bg-primary text-white">
			<div class="row">
				<div class="col-md-8">
					<h3 class="mb-0">Session Code: @Model.SessionCode</h3>
					<p class="mb-0">@Model.Session?.Name</p>
				</div>
				<div class="col-md-4 text-end">
					<span class="badge bg-light text-dark fs-6">@Model.GameMode</span>
					<span class="badge bg-warning text-dark fs-6">@Model.Difficulty</span>
				</div>
			</div>
		</div>
		<div class="card-body">
			<h4>Waiting for game to start...</h4>
			<p class="text-muted">Players joined: @Model.Players?.Count / @Model.Session?.MaxPlayers</p>

			<hr class="my-4">

			<h5 class="mb-3">Players in Lobby:</h5>
			<div class="row">
				@foreach (var player in Model.Players ?? new List<Player>())
				{
					<div class="col-md-2 mb-3">
						<div class="card">
							<div class="card-body text-center py-2">
								<p class="mb-0 fw-bold">@player.Name</p>
							</div>
						</div>
					</div>
				}
			</div>
			<!-- More players will appear here as they join -->
			<div class="col-md-2 mb-3">
				<div class="card bg-light">
					<div class="card-body text-center py-2">
						<p class="mb-0 text-muted">Waiting...</p>
					</div>
				</div>
			</div>
			<div class="col-md-2 mb-3">
				<div class="card bg-light">
					<div class="card-body text-center py-2">
						<p class="mb-0 text-muted">Waiting...</p>
					</div>
				</div>
			</div>
			<div class="col-md-2 mb-3">
				<div class="card bg-light">
					<div class="card-body text-center py-2">
						<p class="mb-0 text-muted">Waiting...</p>
					</div>
				</div>
			</div>
		</div>

		<div class="alert alert-info mt-4">
			<strong>Instructions:</strong> Share the session code <strong>@Model.SessionCode</strong> with your students.
			They can join at <code>/JoinSession</code>
		</div>

		<div class="d-grid gap-2 mt-4">
			<button class="btn btn-success btn-lg" disabled>
				Start Game (Waiting for players...)
			</button>
			<button class="btn btn-outline-secondary">
				Cancel Session
			</button>
		</div>
	</div>
</div>
</div>

<style>
	.card-header h3 {
		font-size: 1.5rem;
	}

	media (max-width: 768px) {
		.card-header .text-end

	{
		text-align: left !important;
		margin-top: 10px;
	}

	}
</style></div>