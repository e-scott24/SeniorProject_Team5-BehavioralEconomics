@page
@model DealtHands.Pages.CreateSessionModel
@{
    ViewData["Title"] = "Create Session";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">Create New Game Session</h2>
                </div>
                <div class="card-body">
                    <form method="post">

                        <div class="mb-3">
                            <label class="form-label">Session Name</label>
                            <input type="text" class="form-control" placeholder="Period 3 - Economics">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Game Mode</label>
                            <div class="btn-group w-100" role="group">
                                <input type="radio" class="btn-check" name="gameMode" id="random" checked>
                                <label class="btn btn-outline-primary" for="random">Random Selection</label>

                                <input type="radio" class="btn-check" name="gameMode" id="structured">
                                <label class="btn btn-outline-primary" for="structured">Structured Play</label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Difficulty</label>
                            <div class="btn-group w-100" role="group">
                                <input type="radio" class="btn-check" name="difficulty" id="easy">
                                <label class="btn btn-outline-success" for="easy">Easy</label>

                                <input type="radio" class="btn-check" name="difficulty" id="medium" checked>
                                <label class="btn btn-outline-warning" for="medium">Medium</label>

                                <input type="radio" class="btn-check" name="difficulty" id="hard">
                                <label class="btn btn-outline-danger" for="hard">Hard</label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Max Players</label>
                            <input type="number" class="form-control" value="35" min="1" max="35">
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Create Session</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>