@page
@model DealtHands.Pages.GameChangerModel
@{
    ViewData["Title"] = "Game Changer";
}


@if (Model.GameChangerUgc != null)
{
    var isPositive = Model.GameChangerUgc.SubmittedAmount > 0;
    <div class="card-header @(isPositive ? "bg-success" : "bg-danger") text-white text-center">
        <h2 class="mb-0">GAME CHANGER!</h2>
    </div>
    <div class="card-body text-center p-4">
        <h4 class="mb-4">@Model.GameChangerUgc.Card.Title</h4>
        <p class="lead">@Model.GameChangerUgc.Card.Description</p>
        <div class="alert @(isPositive ? "alert-success" : "alert-danger") my-4">
            <h3 class="mb-0">@(isPositive ? "+" : "")$@Model.GameChangerUgc.SubmittedAmount?.ToString("N0")</h3>
        </div>
        <form method="post" asp-page-handler="Continue">
            <button type="submit" class="btn btn-primary btn-lg mt-3">Continue Game</button>
        </form>
    </div>
}