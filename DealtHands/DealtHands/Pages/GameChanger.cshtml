@page
@model DealtHands.Pages.GameChangerModel
@{
    ViewData["Title"] = "Game Changer";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white text-center">
                    <h2 class="mb-0">GAME CHANGER!</h2>
                </div>
                <div class="card-body text-center p-4">
                    <h4 class="mb-4">Major Car Repair</h4>

                    <p class="lead">
                        Your transmission failed just 2 months after warranty expired.
                        The mechanic says you need a full replacement.
                    </p>

                    <div class="alert alert-danger my-4">
                        <h3 class="mb-0">-$3,500</h3>
                    </div>

                    <p class="text-muted">
                        You'll need to put this on a credit card at 18% interest.
                    </p>

                    <button class="btn btn-primary btn-lg mt-3">Continue Game</button>
                </div>
            </div>
        </div>
    </div>
</div>
