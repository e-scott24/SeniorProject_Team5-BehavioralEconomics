@page
@model DealtHands.Pages.RoundModel
@{
    ViewData["Title"] = Model.CurrentRound?.RoundType ?? "Round";
}

<h2>ROUND @Model.CurrentRound?.RoundNumber: @Model.CurrentRound?.RoundType?.ToUpper()</h2>

@if (Model.FinancialState != null)
{
    <div class="alert alert-info">
        <strong>Salary:</strong> $@Model.FinancialState.Salary.ToString("N0") |
        <strong>Monthly:</strong> $@Model.FinancialState.MonthlyIncome.ToString("N0") |
        <strong>Available:</strong> $@Model.FinancialState.Available.ToString("N0") |
        <strong>Financial Health:</strong> @Model.FinancialState.FinancialHealth
    </div>
}

@if (!string.IsNullOrEmpty(Model.WaitingMessage))
{
    <p>@Model.WaitingMessage</p>
}
else if (Model.CurrentRound == null)
{
    <p>Waiting for the educator to open the round...</p>
}
else
{
    <form method="post" asp-page-handler="SelectChoice">
        @foreach (var card in Model.Cards)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <h5>@card.Title</h5>
                    <p>@card.Description</p>
                    <p><strong>$@card.MonthlyAmount?.ToString("N0") / month</strong></p>
                    <button type="submit" name="chosenCardId" value="@card.CardId"
                            onclick="document.getElementById('submittedAmount').value = '@card.MonthlyAmount'">
                        Select
                    </button>
                </div>
            </div>
        }
        <input type="hidden" id="submittedAmount" name="submittedAmount" value="0" />
    </form>
}