@page
@model DealtHands.Pages.ForgotPasswordModel

<div class="container mt-5">
	<div class="row justify-content-center">
		<div class="col-md-6">
			<div class="card">
				<div class="card-header">
					<h3>Forgot Password</h3>
				</div>
				<div class="card-body">
					@if (Model.TokenGenerated)
					{
						<div class="alert alert-success">
							<h5>Password Reset Link Generated</h5>
							<p>Click the button below to reset your password:</p>
							<a href="/ResetPassword?token=@Model.Token" class="btn btn-primary">
								Reset My Password
							</a>
							<hr />
							<small class="text-muted">
								(In production, this link would be emailed to you)
							</small>
						</div>
					}
					else
					{
						@if (!string.IsNullOrEmpty(Model.Message))
						{
							<div class="alert alert-danger">@Model.Message</div>
						}

						<form method="post">
							<div class="mb-3">
								<label asp-for="Email" class="form-label">Email</label>
								<input asp-for="Email" class="form-control" type="email" />
								<span asp-validation-for="Email" class="text-danger"></span>
							</div>
							<button type="submit" class="btn btn-primary w-100">Send Reset Link</button>
						</form>
					}
				</div>
			</div>
		</div>
	</div>
</div>

<!-- allows for client side validation -->
@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}
