@page
@model DealtHands.Pages.Round1CareerModel
@{
    ViewData["Title"] = "Round 1 - Career";
}

<div class="container mt-4">
    <!-- Financial Status Header -->
    <div class="alert alert-info">
        <div class="row text-center">
            <div class="col-md-3">
                <strong>Salary:</strong> $@((Model.Player?.Salary ?? 0).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Monthly:</strong> $@((Model.Player?.MonthlyIncome ?? 0).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Available:</strong> $@(((Model.Player?.MonthlyIncome ?? 0) - (Model.Player?.MonthlyExpenses ?? 0)).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Financial Health:</strong> @(Model.Player?.FinancialHealth ?? "Healthy")
            </div>
            <div class="col-md-3">
                <strong>Round:</strong> 1 of 5
            </div>
        </div>
    </div>

    <!-- Round Title -->
    <div class="text-center mb-4">
        <h2>ROUND 1: CAREER</h2>
        <p class="text-muted">Choose your career path</p>
    </div>

    <!-- Career Options -->

    <div class="col-md-4 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Software Developer</h5>
                <p class="card-text">Starting Salary: $65,000/year</p>
                <p class="text-muted">Monthly: $5,417</p>

                <form method="post" asp-page-handler="SelectCareer">
                    <input type="hidden" name="playerId" value="@Model.Player?.Id" />
                    <input type="hidden" name="careerName" value="Software Developer" />
                    <input type="hidden" name="monthlySalary" value="5417" />
					<input type="hidden" name="salary" value="65000" />
                    <button type="submit" class="btn btn-primary w-100">Select</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Teacher</h5>
                <p class="card-text">Starting Salary: $42,000/year</p>
                <p class="text-muted">Monthly: $3,500</p>

                <form method="post" asp-page-handler="SelectCareer">
                    <input type="hidden" name="playerId" value="@Model.Player?.Id" />
                    <input type="hidden" name="careerName" value="Teacher" />
                    <input type="hidden" name="monthlySalary" value="3500" />
					<input type="hidden" name="salary" value="42000" />
                    <button type="submit" class="btn btn-primary w-100">Select</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Nurse</h5>
                <p class="card-text">Starting Salary: $58,000/year</p>
                <p class="text-muted">Monthly: $4,833</p>

                <form method="post" asp-page-handler="SelectCareer">
                    <input type="hidden" name="playerId" value="@Model.Player?.Id" />
                    <input type="hidden" name="careerName" value="Nurse" />
                    <input type="hidden" name="monthlySalary" value="4833" />
					<input type="hidden" name="salary" value="58000" />
                    <button type="submit" class="btn btn-primary w-100">Select</button>
                </form>
            </div>
        </div>
    </div>

</div>