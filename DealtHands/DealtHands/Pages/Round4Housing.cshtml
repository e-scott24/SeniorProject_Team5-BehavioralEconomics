@page
@model DealtHands.Pages.Round4HousingModel
@{
	ViewData["Title"] = "Round 4 - Housing";
}

<div class="container mt-4">
    <!-- Financial Status Header -->
    <div class="alert alert-info">
        <div class="row text-center">
            <div class="col-md-3">
                <strong>Salary:</strong> $@((Model.Player?.Salary ?? 0).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Monthly:</strong> $@((Model.Player?.MonthlyIncome ?? 0).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Available:</strong> $@(((Model.Player?.MonthlyIncome ?? 0) - (Model.Player?.MonthlyExpenses ?? 0)).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Financial Health:</strong> @(Model.Player?.FinancialHealth ?? "Healthy")
            </div>
            <div class="col-md-3">
                <strong>Round:</strong> 4 of 5
            </div>
        </div>
    </div>

	<!-- Round Title -->
	<div class="text-center mb-4">
		<h2>ROUND 4: HOUSING</h2>
		<p class="text-muted">Placholder Text</p>
	</div>

    <!-- Cards -->
    <div class="col-md-4 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Studio Apartment</h5>
                <p class="card-text">Rent: $850/month</p>
                <p class="text-muted">Small, affordable, utilities included</p>
                <form method="post" asp-page-handler="SelectHousing">
                    <input type="hidden" name="playerId" value="@Model.Player?.Id" />
                    <input type="hidden" name="housingDescription" value="Studio Apartment - Rent" />
                    <input type="hidden" name="monthlyPayment" value="850" />
                    <input type="hidden" name="purchasePrice" />
                    <button type="submit" class="btn btn-primary w-100 mt-2">Select</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">2BR Apartment</h5>
                <p class="card-text">Rent: $1,350/month</p>
                <p class="text-muted">Spacious, good location, parking included</p>
                <form method="post" asp-page-handler="SelectHousing">
                    <input type="hidden" name="playerId" value="@Model.Player?.Id" />
                    <input type="hidden" name="housingDescription" value="2BR Apartment - Rent" />
                    <input type="hidden" name="monthlyPayment" value="1350" />
                    <input type="hidden" name="purchasePrice" />
                    <button type="submit" class="btn btn-primary w-100 mt-2">Select</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Starter Home</h5>
                <p class="card-text">Purchase: $200,000</p>
                <p class="text-muted">Mortgage: $1,650/month (30-year, 6% APR)</p>
                <form method="post" asp-page-handler="SelectHousing">
                    <input type="hidden" name="playerId" value="@Model.Player?.Id" />
                    <input type="hidden" name="housingDescription" value="Starter Home - Buy $200,000" />
                    <input type="hidden" name="monthlyPayment" value="1650" />
                    <input type="hidden" name="purchasePrice" value="200000" />
                    <button type="submit" class="btn btn-primary w-100 mt-2">Select</button>
                </form>
            </div>
        </div>
    </div>

</div>
