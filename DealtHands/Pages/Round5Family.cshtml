@page
@model DealtHands.Pages.Round5FamilyModel
@using DealtHands.Pages.Shared
@{
    ViewData["Title"] = "Round 5 - Family";
}

<div class="container mt-4">

    <div class="alert alert-info">
        <div class="row text-center">
            <div class="col-md-3">
                <strong>Salary:</strong> $@((Model.Player?.Salary ?? 0).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Monthly:</strong> $@((Model.Player?.MonthlyIncome ?? 0).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Available:</strong> $@(((Model.Player?.MonthlyIncome ?? 0) - (Model.Player?.MonthlyExpenses ?? 0)).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Financial Health:</strong> @(Model.Player?.FinancialHealth ?? "Healthy")
            </div>
            <div class="col-md-3">
                <strong>Round:</strong> 5 of 5
            </div>
        </div>
    </div>

    <div class="text-center mb-4">
        <h2>ROUND 5: FAMILY</h2>
        <p class="text-muted">What does your family life look like?</p>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Single, No Dependents</h5>
                    <p class="card-text">No children or pets</p>
                    <p class="text-muted">Monthly Cost: $0</p>
                    <button class="btn btn-primary w-100 mt-2"
                            onclick="selectFamily(@Model.Player?.Id, 'Single, No Dependents', 0)">
                        Select
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">One Child</h5>
                    <p class="card-text">Daycare + expenses</p>
                    <p class="text-muted">Monthly Cost: $900</p>
                    <button class="btn btn-primary w-100 mt-2"
                            onclick="selectFamily(@Model.Player?.Id, 'One Child (Daycare + Expenses)', 900)">
                        Select
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Two Children</h5>
                    <p class="card-text">Daycare for 2 + expenses</p>
                    <p class="text-muted">Monthly Cost: $1,600</p>
                    <button class="btn btn-primary w-100 mt-2"
                            onclick="selectFamily(@Model.Player?.Id, 'Two Children (Daycare + Expenses)', 1600)">
                        Select
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<partial name="Cards/_GameChangerOverlay" model='new GameChangerOverlayModel
{
    Cards    = Model.Cards,
    PlayerId = Model.Player?.Id ?? 0,
    NextUrl  = "/Results"
}' />

<script>
    async function selectFamily(playerId, familyDescription, monthlyPayment) {
        const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

        const resp = await fetch('?handler=SelectFamily', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': csrfToken
            },
            body: `playerId=${playerId}&familyDescription=${encodeURIComponent(familyDescription)}&monthlyPayment=${monthlyPayment}`
        });

        const data = await resp.json();
        if (data.success) showCardOverlay();
    }
</script>
