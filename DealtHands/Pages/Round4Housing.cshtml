@page
@model DealtHands.Pages.Round4HousingModel
@using DealtHands.Pages.Shared
@{
    ViewData["Title"] = "Round 4 - Housing";
}

<div class="container mt-4">

    <div class="alert alert-info">
        <div class="row text-center">
            <div class="col-md-3">
                <strong>Salary:</strong> $@((Model.Player?.Salary ?? 0).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Monthly:</strong> $@((Model.Player?.MonthlyIncome ?? 0).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Available:</strong> $@(((Model.Player?.MonthlyIncome ?? 0) - (Model.Player?.MonthlyExpenses ?? 0)).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Financial Health:</strong> @(Model.Player?.FinancialHealth ?? "Healthy")
            </div>
            <div class="col-md-3">
                <strong>Round:</strong> 4 of 5
            </div>
        </div>
    </div>

    <div class="text-center mb-4">
        <h2>ROUND 4: HOUSING</h2>
        <p class="text-muted">Where will you live?</p>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Studio Apartment</h5>
                    <p class="card-text">Rent: $850/month</p>
                    <p class="text-muted">Small, affordable, utilities included</p>
                    <button class="btn btn-primary w-100 mt-2"
                            onclick="selectHousing(@Model.Player?.Id, 'Studio Apartment - Rent', 850, 0)">
                        Select
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">2BR Apartment</h5>
                    <p class="card-text">Rent: $1,350/month</p>
                    <p class="text-muted">Spacious, good location, parking included</p>
                    <button class="btn btn-primary w-100 mt-2"
                            onclick="selectHousing(@Model.Player?.Id, '2BR Apartment - Rent', 1350, 0)">
                        Select
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Starter Home</h5>
                    <p class="card-text">Purchase: $200,000</p>
                    <p class="text-muted">Mortgage: $1,650/month (30-year, 6% APR)</p>
                    <button class="btn btn-primary w-100 mt-2"
                            onclick="selectHousing(@Model.Player?.Id, 'Starter Home - Buy $200,000', 1650, 200000)">
                        Select
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<partial name="Cards/_GameChangerOverlay" model='new GameChangerOverlayModel
{
    Cards    = Model.Cards,
    PlayerId = Model.Player?.Id ?? 0,
    NextUrl  = "/Round5Family"
}' />

<script>
    async function selectHousing(playerId, housingDescription, monthlyPayment, purchasePrice) {
        const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

        const resp = await fetch('?handler=SelectHousing', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': csrfToken
            },
            body: `playerId=${playerId}&housingDescription=${encodeURIComponent(housingDescription)}&monthlyPayment=${monthlyPayment}&purchasePrice=${purchasePrice}`
        });

        const data = await resp.json();
        if (data.success) showCardOverlay();
    }
</script>
