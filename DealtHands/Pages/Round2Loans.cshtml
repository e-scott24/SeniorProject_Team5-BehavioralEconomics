@page
@model DealtHands.Pages.Round2LoansModel
@using DealtHands.Pages.Shared
@{
    ViewData["Title"] = "Round 2 - Student Loans";
}

<div class="container mt-4">

    <div class="alert alert-info">
        <div class="row text-center">
            <div class="col-md-3">
                <strong>Salary:</strong> $@((Model.Player?.Salary ?? 0).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Monthly:</strong> $@((Model.Player?.MonthlyIncome ?? 0).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Available:</strong> $@(((Model.Player?.MonthlyIncome ?? 0) - (Model.Player?.MonthlyExpenses ?? 0)).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Financial Health:</strong> @(Model.Player?.FinancialHealth ?? "Healthy")
            </div>
            <div class="col-md-3">
                <strong>Round:</strong> 2 of 5
            </div>
        </div>
    </div>

    <div class="text-center mb-4">
        <h2>ROUND 2: STUDENT LOANS</h2>
        <p class="text-muted">Choose your loan repayment plan</p>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Small Loan</h5>
                    <p class="card-text">Total: $15,000</p>
                    <p class="text-muted">10-Year Plan</p>
                    <p><strong>$165/month</strong></p>
                    <button class="btn btn-primary w-100"
                            onclick="selectLoan(@Model.Player?.Id, 'Small Loan - $15,000', 165, 15000)">
                        Select
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Medium Loan</h5>
                    <p class="card-text">Total: $35,000</p>
                    <p class="text-muted">10-Year Plan</p>
                    <p><strong>$385/month</strong></p>
                    <button class="btn btn-primary w-100"
                            onclick="selectLoan(@Model.Player?.Id, 'Medium Loan - $35,000', 385, 35000)">
                        Select
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Large Loan</h5>
                    <p class="card-text">Total: $65,000</p>
                    <p class="text-muted">10-Year Plan</p>
                    <p><strong>$715/month</strong></p>
                    <button class="btn btn-primary w-100"
                            onclick="selectLoan(@Model.Player?.Id, 'Large Loan - $65,000', 715, 65000)">
                        Select
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<partial name="Cards/_GameChangerOverlay" model='new GameChangerOverlayModel
{
    Cards    = Model.Cards,
    PlayerId = Model.Player?.Id ?? 0,
    NextUrl  = "/Round3Transportation"
}' />

<script>
    async function selectLoan(playerId, loanDescription, monthlyPayment, totalDebt) {
        const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

        const resp = await fetch('?handler=SelectLoan', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': csrfToken
            },
            body: `playerId=${playerId}&loanDescription=${encodeURIComponent(loanDescription)}&monthlyPayment=${monthlyPayment}&totalDebt=${totalDebt}`
        });

        const data = await resp.json();
        if (data.success) showCardOverlay();
    }
</script>
