@page
@model DealtHands.Pages.SessionReportModel
@{
    ViewData["Title"] = "Session Report";
}

<div class="container mt-4" id="session-report-content">
    <div class="d-flex justify-content-between align-items-center mb-4 no-print">
        <h2>Session Report: @Model.Session?.Name</h2>
        <div>
            <a href="/SessionReport?handler=DownloadPdf&sessionId=@Model.Session?.GameSessionId"
               class="btn btn-success me-2">
                Download as PDF
            </a>
            <a href="/EducatorDashboard" class="btn btn-secondary">Back to Dashboard</a>
        </div>
    </div>

    <!-- For PDF: Show title when buttons are hidden -->
    <div class="print-only" style="display: none;">
        <h2 class="mb-4">Session Report: @Model.Session?.Name</h2>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Session Details</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <p class="mb-2"><strong>Join Code:</strong> @Model.Session?.JoinCode</p>
                </div>
                <div class="col-md-3">
                    <p class="mb-2"><strong>Mode:</strong> @Model.Session?.Game?.Mode</p>
                </div>
                <div class="col-md-3">
                    <p class="mb-2"><strong>Difficulty:</strong> @Model.Session?.Difficulty</p>
                </div>
                <div class="col-md-3">
                    <p class="mb-2"><strong>Players:</strong> @Model.Leaderboard?.Count</p>
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-md-6">
                    <p class="mb-2"><strong>Started:</strong> @Model.Session?.StartedAt?.ToString("MM/dd/yyyy hh:mm tt")</p>
                </div>
                <div class="col-md-6">
                    <p class="mb-2"><strong>Completed:</strong> @Model.Session?.EndedAt?.ToString("MM/dd/yyyy hh:mm tt")</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Final Leaderboard</h5>
        </div>
        <div class="card-body">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Player</th>
                        <th>Final Score</th>
                        <th>Choices Made</th>
                        <th>Financial Health</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int rank = 1;
                    }
                    @foreach (var entry in Model.Leaderboard)
                    {
                        <tr>
                            <td>
                                @if (rank == 1)
                                {
                                    <span class="badge bg-warning text-dark">🏆 #@rank</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">#@rank</span>
                                }
                            </td>
                            <td>@entry.Username</td>
                            <td class="@(entry.CurrentScore >= 0 ? "text-success" : "text-danger")">
                                $@entry.CurrentScore.ToString("N2")
                            </td>
                            <td>@entry.CardsSubmitted</td>
                            <td>
                                @{
                                    var state = Model.PlayerStates?.FirstOrDefault(s => s.UserId == entry.UserId);
                                    var health = state?.FinancialHealth ?? "Unknown";
                                    var badgeClass = health == "Healthy" ? "bg-success" : health == "Struggling" ? "bg-warning" : "bg-danger";
                                }
                                <span class="badge @badgeClass">@health</span>
                            </td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">Round-by-Round Summary</h5>
        </div>
        <div class="card-body">
            @for (int roundNum = 1; roundNum <= 5; roundNum++)
            {
                var roundData = Model.RoundSummaries?.FirstOrDefault(r => r.RoundNumber == roundNum);
                if (roundData != null)
                {
                    <h6 class="mt-3">Round @roundNum: @roundData.RoundType</h6>
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Player</th>
                                <th>Card Chosen</th>
                                <th>Amount</th>
                                <th>Running Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in roundData.Results)
                            {
                                <tr>
                                    <td>@result.Username</td>
                                    <td>
                                        @result.CardTitle
                                        @if (result.IsGameChanger)
                                        {
                                            <span class="badge bg-warning text-dark ms-1">Game Changer</span>
                                        }
                                    </td>
                                    <td class="@(result.SubmittedAmount >= 0 ? "text-success" : "text-danger")">
                                        @(result.SubmittedAmount >= 0 ? "+" : "")$@result.SubmittedAmount?.ToString("N2")
                                    </td>
                                    <td class="@(result.RunningTotal >= 0 ? "text-success" : "text-danger")">
                                        $@result.RunningTotal?.ToString("N2")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
        </div>
    </div>
</div>

