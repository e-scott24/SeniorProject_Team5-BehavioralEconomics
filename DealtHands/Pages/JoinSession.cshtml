@page
@model DealtHands.Pages.JoinSessionModel
@{
    ViewData["Title"] = "Join Session";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow text-center">
                <div class="card-body p-5">
                    <h1 class="mb-4">DEALT HANDS</h1>
                    <h4 class="text-muted mb-4">Join a Game Session</h4>

                    <form method="post">
                        <div class="mb-4">
                            <label class="form-label">Session Code</label>
                            <input type="text" class="form-control form-control-lg text-center"
                                   asp-for="SessionCode"
                                   placeholder="12345" maxlength="5" 
                                   style="font-size: 2em; letter-spacing: 0.5em;">
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Your Name</label>
                            <input type="text" class="form-control" 
                                   asp-for="PlayerName"
                                   placeholder="Enter your name">
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg">Join Game</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>