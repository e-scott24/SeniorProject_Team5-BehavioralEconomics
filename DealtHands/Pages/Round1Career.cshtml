@page
@model DealtHands.Pages.Round1CareerModel
@using DealtHands.Pages.Shared
@{
    ViewData["Title"] = "Round 1 - Career";
}

@* ── Main page content ────────────────────────────────────────────── *@
<div class="container mt-4">

    @* Financial Status Header *@
    <div class="alert alert-info">
        <div class="row text-center">
            <div class="col-md-3">
                <strong>Salary:</strong> $@((Model.Player?.Salary ?? 0).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Monthly:</strong> $@((Model.Player?.MonthlyIncome ?? 0).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Available:</strong> $@(((Model.Player?.MonthlyIncome ?? 0) - (Model.Player?.MonthlyExpenses ?? 0)).ToString("N0"))
            </div>
            <div class="col-md-3">
                <strong>Financial Health:</strong> @(Model.Player?.FinancialHealth ?? "Healthy")
            </div>
            <div class="col-md-3">
                <strong>Round:</strong> 1 of 5
            </div>
        </div>
    </div>

    @* Round Title *@
    <div class="text-center mb-4">
        <h2>ROUND 1: CAREER</h2>
        <p class="text-muted">Choose your career path</p>
    </div>

    @* Career Options *@
    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Software Developer</h5>
                    <p class="card-text">Starting Salary: $65,000/year</p>
                    <p class="text-muted">Monthly: $5,417</p>
                    <button class="btn btn-primary w-100"
                            onclick="selectCareer(@Model.Player?.Id, 'Software Developer', 5417, 65000)">
                        Select
                    </button>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Teacher</h5>
                    <p class="card-text">Starting Salary: $42,000/year</p>
                    <p class="text-muted">Monthly: $3,500</p>
                    <button class="btn btn-primary w-100"
                            onclick="selectCareer(@Model.Player?.Id, 'Teacher', 3500, 42000)">
                        Select
                    </button>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Nurse</h5>
                    <p class="card-text">Starting Salary: $58,000/year</p>
                    <p class="text-muted">Monthly: $4,833</p>
                    <button class="btn btn-primary w-100"
                            onclick="selectCareer(@Model.Player?.Id, 'Nurse', 4833, 58000)">
                        Select
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@* CSRF token — required by the overlay's fetch POSTs *@
@Html.AntiForgeryToken()

@* ── Shared Game Changer overlay ─────────────────────────────────────
   Renders the card CSS, overlay HTML, and JS in one line.
   NextUrl is where the player goes after all cards are done.
──────────────────────────────────────────────────────────────────── *@
<partial name="Cards/_GameChangerOverlay" model='new GameChangerOverlayModel
{
    Cards    = Model.Cards,
    PlayerId = Model.Player?.Id ?? 0,
    NextUrl  = "/Round2Loans"
}' />

<script>
    // Submits career choice via fetch, then triggers the card overlay.
    async function selectCareer(playerId, careerName, monthlySalary, salary) {
        const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

        const resp = await fetch('?handler=SelectCareer', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': csrfToken
            },
            body: `playerId=${playerId}&careerName=${encodeURIComponent(careerName)}&monthlySalary=${monthlySalary}&salary=${salary}`
        });

        const data = await resp.json();

        if (data.success) {
            showCardOverlay(); // defined by _GameChangerOverlay.cshtml
        }
    }
</script>
