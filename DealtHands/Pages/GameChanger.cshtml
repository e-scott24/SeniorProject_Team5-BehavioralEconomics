@*  Name: Jason Black
    Date: 3/20/2026
    Last Update: 3/21/2026

    Standalone Game Changer card sequence page.
    Round 1 does not use this page — it handles cards inline via _GameChangerOverlay.cshtml.
    All cards are rendered into the DOM at load. JS sequences them on Continue click.

    The correct file paths are the following:
    ...\DealtHands\DealtHands\Services\GameChangerService.cs
    ...\DealtHands\DealtHands\Services\GameEngine.cs
    ...\DealtHands\DealtHands\Models\GameChangerEvent.cs
    ...\DealtHands\DealtHands\Models\Cards\GameChangerCard.cs
    ...\DealtHands\DealtHands\Pages\Shared\GameChangerOverlayModel.cs
    ...\DealtHands\DealtHands\Pages\Shared\Cards\_GameChangerCard.cshtml
    ...\DealtHands\DealtHands\Pages\Shared\Cards\_GameChangerOverlay.cshtml
*@

@page
@model DealtHands.Pages.GameChangerModel
@{
    ViewData["Title"] = "Game Changer";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

<style>
    .card-slot {
        display: none;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 40px 20px;
        background: #ffffff;
    }

    .card-slot.active {
        display: flex;
    }

    .gc-card-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .gc-peek {
        width: 340px;
        height: 28px;
        background: #fff;
        border: 2px solid #d1d5db;
        border-bottom: none;
        border-radius: 20px 20px 0 0;
        opacity: 0.5;
        transform: scaleX(0.92);
        transform-origin: bottom;
    }

    .gc-card {
        width: 340px;
        background: #ffffff;
        border-radius: 20px;
        border: 2px solid;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0,0,0,0.04), 0 20px 40px rgba(0,0,0,0.10);
        animation: gc-rise 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    @@keyframes gc-rise {
        from { opacity: 0; transform: translateY(20px) scale(0.97); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    .gc-header {
        padding: 18px 24px 16px;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 72px;
    }

    .gc-header::before {
        content: '';
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
            -45deg, transparent, transparent 8px,
            rgba(255,255,255,0.08) 8px, rgba(255,255,255,0.08) 16px
        );
    }

    .gc-header-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.45rem;
        font-weight: 900;
        letter-spacing: 0.12em;
        color: #fff;
        text-transform: uppercase;
        position: relative;
        z-index: 1;
        text-shadow: 0 1px 3px rgba(0,0,0,0.18);
    }

    .gc-body {
        padding: 24px 24px 28px;
        background: #fff;
    }

    .gc-category {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    .gc-title {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 700;
        color: #111827;
        line-height: 1.1;
        margin-bottom: 14px;
    }

    .gc-desc {
        font-size: 0.92rem;
        color: #374151;
        line-height: 1.65;
        margin-bottom: 22px;
    }

    .gc-effect-box {
        border-radius: 10px;
        border: 1.5px solid;
        padding: 14px 18px;
        margin-bottom: 14px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        animation: gc-pop 0.5s 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @@keyframes gc-pop {
        from { opacity: 0; transform: scale(0.9); }
        to   { opacity: 1; transform: scale(1); }
    }

    .gc-effect-label {
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    .gc-effect-amount {
        font-family: 'Playfair Display', serif;
        font-size: 1.7rem;
        font-weight: 700;
        letter-spacing: -0.01em;
    }

    .gc-badge {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 999px;
        margin-top: 4px;
        width: fit-content;
    }

    .gc-divider {
        height: 1px;
        margin: 8px 0;
    }

    .gc-note {
        font-size: 0.78rem;
        color: #6b7280;
        line-height: 1.5;
        margin-bottom: 22px;
    }

    .gc-btn {
        display: block;
        width: 100%;
        padding: 15px;
        background: #111827;
        color: #fff;
        border: none;
        border-radius: 999px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        cursor: pointer;
        transition: background 0.18s, transform 0.14s, box-shadow 0.18s;
        box-shadow: 0 4px 14px rgba(0,0,0,0.18);
    }

    .gc-btn:hover {
        background: var(--btn-hover-bg);
        box-shadow: 0 6px 20px var(--btn-hover-shadow);
        transform: translateY(-2px);
    }

    .gc-btn:active {
        transform: translateY(0);
        box-shadow: 0 2px 6px rgba(0,0,0,0.12);
    }
</style>

<div id="card-stack">
    @for (int i = 0; i < Model.Cards.Count; i++)
    {
        <div class="card-slot @(i == 0 ? "active" : "")" data-index="@i">
            <partial name="Cards/_GameChangerCard" model="Model.Cards[i]" />
        </div>
    }
</div>

@Html.AntiForgeryToken()

<script>
    let current = 0;
    const slots = document.querySelectorAll('.card-slot');

    const cardMeta = [
        @for (int i = 0; i < Model.Cards.Count; i++)
        {
                @:{ id: @Model.Cards[i].Id }@(i < Model.Cards.Count - 1 ? "," : "")
        }
    ];

    const playerId    = @Model.PlayerId;
    const round       = @Model.Round;
    const nextRound   = @Model.NextRound;
    const nextRoundUrl = '@Url.Page(Model.NextRoundPage, new { playerId = Model.PlayerId })';
    const csrfToken   = document.querySelector('input[name="__RequestVerificationToken"]').value;

    async function nextCard() {
        await fetch('?handler=ApplyCard', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': csrfToken
            },
            body: `playerId=${playerId}&cardId=${cardMeta[current].id}&round=${round}&nextRound=${nextRound}`
        });

        slots[current].classList.remove('active');
        current++;

        if (current < slots.length) {
            slots[current].classList.add('active');
        } else {
            window.location.href = nextRoundUrl;
        }
    }
</script>
