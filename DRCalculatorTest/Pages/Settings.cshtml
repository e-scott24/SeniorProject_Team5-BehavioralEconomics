    Date: 3/4/2026
    Last Update: 3/4/2026

    This is a testing page for difficulty settings
*@

@page
@model DealtHands.Pages.DifficultySettingsModel
@{
    ViewData["Title"] = "Difficulty Settings";
    var current = Model.CurrentDifficulty;
}

<style>
    .ds-wrap {
        max-width: 560px;
        margin: 3rem auto;
        padding: 0 1rem;
        font-family: -apple-system, 'Segoe UI', system-ui, sans-serif;
    }

    .ds-heading {
        font-size: 1.2rem;
        font-weight: 700;
        color: #1e3a5f;
        margin-bottom: .35rem;
    }

    .ds-sub {
        font-size: .82rem;
        color: #64748b;
        margin-bottom: 1.5rem;
    }

    .ds-grid {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
    }

        .ds-grid form {
            flex: 1;
            min-width: 140px;
        }

    .ds-btn {
        width: 100%;
        padding: .7rem 1rem;
        border-radius: 10px;
        border: 2px solid var(--accent);
        background: transparent;
        color: var(--accent);
        font-family: inherit;
        font-size: .9rem;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s, color .15s;
        min-height: 44px;
    }

        .ds-btn:hover, .ds-btn.active {
            background: var(--accent);
            color: #fff;
        }

        .ds-btn:disabled {
            opacity: .4;
            cursor: not-allowed;
            pointer-events: none;
        }

    .ds-btn-easy {
        --accent: #2563eb;
    }

    .ds-btn-medium {
        --accent: #f59e0b;
    }

    .ds-btn-hard {
        --accent: #ef4444;
    }

    .ds-note {
        margin-top: 1.25rem;
        font-size: .75rem;
        color: #94a3b8;
    }
</style>

<div class="ds-wrap">

    <div class="ds-heading">Difficulty Settings</div>
    <p class="ds-sub">Active: <strong>@current</strong> — Medium and Hard are not yet implemented.</p>

    <div class="ds-grid">

        <form method="post">
            <input type="hidden" name="difficulty" value="easy" />
            <button type="submit" class="ds-btn ds-btn-easy @(current == "easy" ? "active" : "")">
                Easy @(current == "easy" ? "✓" : "")
            </button>
        </form>

        <form>
            <button type="button" class="ds-btn ds-btn-medium" disabled>Medium (soon)</button>
        </form>

        <form>
            <button type="button" class="ds-btn ds-btn-hard" disabled>Hard (soon)</button>
        </form>

    </div>

    <p class="ds-note">
        This page is for development use. When Medium/Hard are ready, add their POST forms
        and update OnPost() in DifficultySettings.cshtml.cs to accept the new values.
    </p>

</div>
